---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Page not found | SE Hot Water"
  description="The page you were looking for couldn't be found. No hot water? Call us on (03) 9003 0108 — same-day across South East Melbourne.">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>

  <section class="hero">
    <div class="hero-inner" style="text-align:center;">
      <span class="hero-eyebrow">404</span>
      <h1 style="margin-left:auto; margin-right:auto;">Couldn&rsquo;t find that page.</h1>
      <p class="hero-sub" style="margin-left:auto; margin-right:auto;">
        Try the home page or call us &mdash; if your hot water&rsquo;s out we can usually be on site
        within 2&ndash;4 hours across Berwick, Cranbourne, Narre Warren, Hampton Park and Endeavour Hills.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="tel:+61390030108">&#9742; (03) 9003 0108</a>
      </div>
    </div>
  </section>
</Layout>
